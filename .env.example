# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Atlas Connection String
MONGO_URI=""

# JWT Security Signature key
JWT_SECRET=""

# Outgoing Emails Configuration
#
# Choose ONE of the following methods:
#
# METHOD 1: Direct Resend HTTP API (Highly Recommended for Render, no SMTP blocking issue)
# 1. Sign up at resend.com
# 2. Generate an API Key
# 3. Set these two values:
RESEND_API_KEY="re_1234567890abcdef"
SMTP_FROM="onboarding@resend.dev" # Change this to your verified domain once verified

# METHOD 2: SMTP Port Delivery via Resend (Fallback)
# Set these values if you prefer standard SMTP:
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_1234567890abcdef"
# SMTP_FROM="onboarding@resend.dev"
